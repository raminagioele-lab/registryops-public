{
  "phase": "phase2",
  "surface_rules": {
    "oci_manifest": {
      "asset_ref": {
        "grammar": "<registry>/<repository>:<tag>",
        "pattern": "^[a-z0-9.-]+(?::[0-9]+)?/[a-z0-9._-]+(?:/[a-z0-9._-]+)*:[A-Za-z0-9._-]+$"
      },
      "source_ref": {
        "description": "Absolute HTTPS URI to the public canonical resource used to resolve the tag.",
        "binding": "exact_uri_derived_from_asset_ref",
        "canonical_template": "https://<registry>/v2/<repository>/manifests/<tag>",
        "allowed_hosts": [
          "registry-1.docker.io"
        ]
      }
    },
    "npm_package_metadata": {
      "asset_ref": {
        "grammar": "<package_name>@<version>",
        "pattern": "^(?:@[a-z0-9._-]+/)?[a-z0-9._-]+@[A-Za-z0-9][A-Za-z0-9.+_-]*$"
      },
      "source_ref": {
        "description": "Absolute HTTPS URI to the public canonical npm registry resource used to observe the package version.",
        "binding": "exact_uri_derived_from_asset_ref",
        "canonical_template": "https://registry.npmjs.org/<percent-encoded-package-name>/<version>",
        "allowed_hosts": [
          "registry.npmjs.org"
        ]
      }
    },
    "pypi_release_metadata": {
      "asset_ref": {
        "grammar": "<normalized_project_name>==<version>",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*==[^=\\s]+$"
      },
      "source_ref": {
        "description": "Absolute HTTPS URI to the public canonical PyPI resource used to observe the release.",
        "binding": "exact_uri_derived_from_asset_ref",
        "canonical_template": "https://pypi.org/pypi/<normalized-project-name>/<version>/json",
        "allowed_hosts": [
          "pypi.org"
        ]
      }
    },
    "ietf_internet_draft": {
      "asset_ref": {
        "grammar": "<draft-name>-<version>",
        "pattern": "^draft-[a-z0-9-]+-[0-9]{2}$"
      },
      "source_ref": {
        "description": "Absolute HTTPS URI to the public canonical IETF resource used to observe the draft version.",
        "binding": "exact_uri_derived_from_asset_ref",
        "canonical_template": "https://www.ietf.org/archive/id/<draft-name>-<version>.txt",
        "allowed_hosts": [
          "datatracker.ietf.org",
          "www.ietf.org",
          "ietf.org"
        ]
      }
    },
    "maven_central_artifact_metadata": {
      "asset_ref": {
        "grammar": "<group_id>:<artifact_id>:<version>:<extension>",
        "pattern": "^[A-Za-z0-9_.-]+:[A-Za-z0-9_.-]+:[A-Za-z0-9][A-Za-z0-9_.+~-]*:[A-Za-z0-9][A-Za-z0-9_.-]*$"
      },
      "source_ref": {
        "description": "Absolute HTTPS URI to the canonical Maven Central artifact resource.",
        "binding": "exact_uri_derived_from_asset_ref",
        "canonical_template": "https://repo1.maven.org/maven2/<group-path>/<artifact-id>/<version>/<artifact-id>-<version>.<extension>",
        "allowed_hosts": [
          "repo1.maven.org"
        ]
      }
    },
    "crates_io_package_index_metadata": {
      "asset_ref": {
        "grammar": "<crate_name>@<version>",
        "pattern": "^[a-z0-9_-]+@[A-Za-z0-9][A-Za-z0-9.+_-]*$"
      },
      "source_ref": {
        "description": "Absolute HTTPS URI to the canonical crates.io sparse index resource for the crate.",
        "binding": "exact_uri_derived_from_asset_ref",
        "canonical_template": "https://index.crates.io/<canonical-sparse-index-path-for-crate-name>",
        "allowed_hosts": [
          "index.crates.io"
        ],
        "path_pattern": "^/(?:1/[a-z0-9_-]|2/[a-z0-9_-]{2}|3/[a-z0-9_-]/[a-z0-9_-]{3}|[a-z0-9_-]{2}/[a-z0-9_-]{2}/[a-z0-9_-]+)$"
      }
    }
  }
}
