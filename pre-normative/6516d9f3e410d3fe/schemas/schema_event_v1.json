{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "asset_ref",
    "surface_type",
    "event_type",
    "observed_at",
    "source_ref",
    "confidence_level"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "asset_ref": { "type": "string" },
    "surface_type": {
      "type": "string",
      "enum": [
        "public_web_resource",
        "public_api_reference",
        "public_dataset_metadata"
      ]
    },
    "event_type": {
      "type": "string",
      "enum": [
        "resource_first_seen",
        "resource_changed",
        "resource_removed",
        "metadata_changed"
      ]
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_ref": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "confidence_level": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "observation_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}